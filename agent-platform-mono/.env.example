# ── App ──────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
HOST=0.0.0.0
PORT=8000
CHECKPOINT_BACKEND=memory
ORCH_DEFAULT_MODE=command
ORCH_MAX_STEPS=12
ORCH_MAX_REPLANS=2
ORCH_PLAN_EXECUTE_AGENTS=
ORCH_PLAN_EXECUTE_TENANTS=

# ── LLM ──────────────────────────────────────────────────────
LLM_DEFAULT_MODEL=openai/gpt-4o-mini
LLM_STRONG_MODEL=openai/gpt-4o
LLM_MEDIUM_MODEL=openai/gpt-4o-mini
LLM_NANO_MODEL=openai/gpt-4o-mini
LLM_LOCAL_MODEL=ollama/qwen2.5
LLM_ROUTER_DEPLOYMENTS=
LLM_ROUTER_COOLDOWN_SECONDS=30
LLM_ROUTER_MAX_ATTEMPTS=3
LLM_CACHE_ENABLED=true
LLM_CACHE_DEFAULT_TTL_SECONDS=0
LLM_CACHE_SCENE_TTL=
LLM_CACHE_TASK_TTL=
LLM_CACHE_MAX_ENTRIES=512
OPENAI_API_KEY=sk-xxx
ANTHROPIC_API_KEY=sk-ant-xxx
LOCAL_MODEL_BASE_URL=http://localhost:8080/v1   # vLLM / Ollama

# ── Nacos（留空则跳过，纯 .env 模式运行）────────────────────
NACOS_SERVER_ADDR=                              # 如：nacos-server:8848
NACOS_NAMESPACE=agent-platform
NACOS_GROUP=DEFAULT_GROUP
NACOS_DATA_ID=agent-platform.json

# ── Vector DB ────────────────────────────────────────────────
VECTOR_DB_BACKEND=milvus
MILVUS_HOST=localhost
MILVUS_PORT=19530
QDRANT_URL=http://localhost:6333               # mem0 使用

# ── Embedding / Rerank（本地模型，数据不出内网）──────────────
EMBEDDING_MODEL=BAAI/bge-m3
RERANK_MODEL=BAAI/bge-reranker-v2-m3
EMBEDDING_DEVICE=cpu                           # GPU 改为 cuda

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CHECKPOINT_TTL=86400

# ── Internal Spring Cloud Gateway ───────────────────────────
INTERNAL_GATEWAY_URL=http://internal-gateway:8080
GATEWAY_TIMEOUT=30.0

# ── Observability（Langfuse 自托管）──────────────────────────
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_PUBLIC_KEY=pk-lf-xxx
LANGFUSE_SECRET_KEY=sk-lf-xxx
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
